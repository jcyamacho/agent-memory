{
  "name": "@jcyamacho/agent-memory",
  "main": "dist/index.js",
  "version": "0.3.0",
  "bin": {
    "agent-memory": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcyamacho/agent-memory.git"
  },
  "scripts": {
    "build": "bun build src/index.ts --target=node --outfile dist/index.js --banner \"#!/usr/bin/env node\"",
    "start": "node dist/index.js",
    "test": "bun test",
    "lint": "biome check --write && tsc --noEmit",
    "release:patch": "npm version patch && git push origin main --follow-tags",
    "release:minor": "npm version minor && git push origin main --follow-tags",
    "release:major": "npm version major && git push origin main --follow-tags"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": "^5.9.3 || ^6.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "zod": "4.4.3"
  }
}
